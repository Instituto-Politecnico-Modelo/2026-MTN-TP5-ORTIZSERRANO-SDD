# =============================================================================
# backup.env.example
# Sistema de Decanato IPM — Variables de entorno para el sistema de backups
#
# Copiar este archivo a /etc/decanato/backup.env y completar los valores.
# Asegurar permisos: chmod 600 /etc/decanato/backup.env
#
# =============================================================================

# ── Base de datos MySQL ───────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=decanato_db
DB_USER=decanato_backup_user
DB_PASSWORD=CAMBIAR_POR_PASSWORD_REAL

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_PROFILE=decanato-backup
AWS_REGION=us-east-1

# Bucket S3 (creado con setup-s3-bucket.sh)
S3_BUCKET=decanato-ipm-backups
S3_PREFIX=backups

# KMS Key ID para cifrado del lado servidor (output de setup-s3-bucket.sh)
KMS_KEY_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Cifrado local (antes de subir a S3) ──────────────────────────────────────
# Archivo con la passphrase para OpenSSL AES-256-CBC
# Generar con: openssl rand -hex 32 > /etc/decanato/backup-encrypt.key
# Permisos   : chmod 400 /etc/decanato/backup-encrypt.key
ENCRYPT_KEY_FILE=/etc/decanato/backup-encrypt.key

# ── Alertas y monitoreo ───────────────────────────────────────────────────────
# ARN del topic SNS para alertas de backup fallido / días faltantes
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:CUENTA_ID:decanato-backups-alertas

# Nombre del Log Group en CloudWatch
LOG_GROUP=/decanato/backups

# ── Bucket de logs de acceso (creado por setup-s3-bucket.sh) ─────────────────
LOG_BUCKET=decanato-ipm-backups-access-logs
