{
  "clientName": "Thunder Client",
  "collectionName": "Sistema Decanato JWT",
  "collectionId": "decanato-jwt-api",
  "dateExported": "2026-04-13",
  "version": "1.0",
  "folders": [],
  "requests": [
    {
      "name": "1. Registrar Usuario",
      "method": "POST",
      "url": "http://localhost:8080/api/auth/signup",
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "type": "json",
        "raw": "{\n  \"nombre\": \"Juan\",\n  \"apellido\": \"Pérez\",\n  \"email\": \"juan@test.com\",\n  \"password\": \"password123\"\n}"
      }
    },
    {
      "name": "2. Login (Obtener Token)",
      "method": "POST",
      "url": "http://localhost:8080/api/auth/login",
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "type": "json",
        "raw": "{\n  \"email\": \"juan@test.com\",\n  \"password\": \"password123\"\n}"
      },
      "tests": [
        {
          "type": "set-env-var",
          "value": "{{token}}",
          "action": "json.token"
        }
      ]
    },
    {
      "name": "3. Obtener Usuario (Con Token)",
      "method": "GET",
      "url": "http://localhost:8080/api/auth/me",
      "auth": {
        "type": "bearer",
        "bearer": "{{token}}"
      }
    },
    {
      "name": "4. Sin Token (Debe Fallar)",
      "method": "GET",
      "url": "http://localhost:8080/api/auth/me"
    }
  ]
}
