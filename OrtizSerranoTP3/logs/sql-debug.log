        u1_1.rol,
        u1_2.departamento,
        u1_2.especialidad,
        u1_2.titulo,
        u1_3.anio_ingreso,
        u1_3.carrera,
        u1_3.legajo 
    from
        usuarios u1_0 
    left join
        administradores u1_1 
            on u1_0.id_usuario=u1_1.id_usuario 
    left join
        docentes u1_2 
            on u1_0.id_usuario=u1_2.id_usuario 
    left join
        estudiantes u1_3 
            on u1_0.id_usuario=u1_3.id_usuario 
    where
        u1_0.email=?
